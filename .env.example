# goob config — copy to `.env` and fill in one provider block.  cp .env.example .env
#
# `just daemon` auto-loads this file (no need to source it). The Godot app also
# reads DEBUG from here. GOOB_MODEL is the litellm model string; the matching
# key/creds are read from the environment.

# ── Google AI Studio — simplest, just an API key ──────────────────────────
# Get a key at https://aistudio.google.com/apikey (must allow the Generative
# Language API). This is the easiest path.
GOOB_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your-ai-studio-key

# ── OpenAI ────────────────────────────────────────────────────────────────
# GOOB_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ── Google Vertex AI — OAuth, NOT an API key ──────────────────────────────
# Vertex authenticates via a service account or ADC (`gcloud auth application-
# default login`), and needs the [google] extra (`litellm[google]` in
# pyproject.toml). A plain API key does not work with Vertex.
# GOOB_MODEL=vertex_ai/gemini-2.5-flash
# VERTEXAI_PROJECT=your-gcp-project-id
# VERTEXAI_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json   # or use ADC

# ── Fully local via Ollama — no key, nothing leaves your machine ──────────
# GOOB_MODEL=ollama/llama3

# ── Godot debug overlay (read by the app, not the daemon) ─────────────────
# DEBUG=true
