# goob config — copy to `.env` and set one provider. `just daemon` auto-loads it.
# Providers, auth, triggering, and every option: docs/llm-commentary.md

# Google AI Studio — simplest (just a key). Also supported: OpenAI, Vertex AI, Ollama.
GOOB_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=

# DEBUG=true   # Godot state overlay (read by the app, not the daemon)
